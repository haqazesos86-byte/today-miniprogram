.page { min-height: 100vh; padding: 32rpx 40rpx 60rpx; background: #fafafa; box-sizing: border-box; }
.stat-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; margin-bottom: 32rpx; }
.stat-card { background: #fff; padding: 32rpx 16rpx; text-align: center; border: 1rpx solid rgba(199,199,204,0.3); }
.stat-num { font-size: 56rpx; font-weight: 600; line-height: 1.1; color: #1f8a4c; }
.stat-num.orange { color: #ff9500; }
.stat-unit { font-size: 28rpx; font-weight: 400; color: #86868b; }
.stat-label { font-size: 24rpx; color: #86868b; margin-top: 8rpx; }
.cum-grid { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16rpx; }
.cum-item { text-align: center; padding: 8rpx; }
.cum-num { font-size: 32rpx; font-weight: 600; color: #1d1d1f; line-height: 1.1; }
.cum-num.accent { color: #1f8a4c; }
.cum-label { font-size: 22rpx; color: #86868b; margin-top: 4rpx; }
.view-tabs { display: flex; background: #f0f0f0; margin-bottom: 24rpx; padding: 4rpx; }
.view-tab { flex: 1; text-align: center; padding: 12rpx 0; font-size: 26rpx; color: #86868b; transition: all 0.2s ease; }
.view-tab.active { background: #fff; color: #1d1d1f; font-weight: 500; }
.section { background: #fff; padding: 32rpx 24rpx; margin-bottom: 24rpx; border: 1rpx solid rgba(199,199,204,0.3); }
.section-title { font-size: 28rpx; font-weight: 600; color: #1d1d1f; margin-bottom: 24rpx; }
.chart-wrapper { width: 100%; height: 360rpx; }
.trend-chart { width: 100%; height: 360rpx; }
.calendar-grid { display: grid; grid-template-columns: repeat(15, 1fr); gap: 4rpx; }
.cal-cell { aspect-ratio: 1; background: #fafafa; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding: 4rpx 2rpx; border: 1rpx solid transparent; transition: all 0.2s ease; }
.cal-cell.has-tasks { background: #fff; border-color: rgba(199,199,204,0.3); }
.cal-cell.complete { background: rgba(31,138,76,0.05); border-color: #1f8a4c; }
.cal-day { font-size: 18rpx; color: #86868b; margin-bottom: 2rpx; }
.cal-cell.complete .cal-day { color: #1f8a4c; font-weight: 600; }
.cal-bar { flex: 1; width: 6rpx; background: #f0f0f0; display: flex; align-items: flex-end; margin-top: 2rpx; }
.cal-bar-fill { width: 100%; transition: height 0.6s ease; }
.day-list { display: flex; flex-direction: column; }
.day-row { display: flex; align-items: center; padding: 18rpx 0; gap: 20rpx; }
.day-info { width: 120rpx; flex-shrink: 0; }
.day-name { font-size: 26rpx; font-weight: 500; color: #1d1d1f; }
.day-date { font-size: 22rpx; color: #86868b; margin-top: 2rpx; }
.day-bar { flex: 1; }
.day-bar-track { width: 100%; height: 12rpx; background: #f0f0f0; position: relative; overflow: hidden; }
.day-bar-fill { height: 100%; background: #c7c7cc; transition: width 0.6s ease; }
.day-num { width: 100rpx; text-align: right; font-size: 24rpx; flex-shrink: 0; }
.day-done { color: #1f8a4c; font-weight: 600; }
.day-total { color: #c7c7cc; }
.empty { display: flex; flex-direction: column; align-items: center; padding: 120rpx 0; }
.empty-emoji { font-size: 80rpx; margin-bottom: 16rpx; }
.empty-text { font-size: 32rpx; color: #86868b; margin-bottom: 8rpx; }
.empty-hint { font-size: 24rpx; color: #c7c7cc; }
