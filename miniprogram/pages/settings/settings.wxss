.page { min-height: 100vh; padding: 32rpx 40rpx 60rpx; background: #fafafa; box-sizing: border-box; }
.section { background: #fff; padding: 32rpx; margin-bottom: 24rpx; border: 1rpx solid rgba(199,199,204,0.3); }
.section-title { font-size: 26rpx; font-weight: 600; color: #1d1d1f; margin-bottom: 24rpx; }
.theme-list { display: flex; gap: 16rpx; }
.theme-item { flex: 1; text-align: center; padding: 16rpx 0; border: 2rpx solid transparent; cursor: pointer; transition: border-color 0.2s; }
.theme-item.active { border-color: #1f8a4c; }
.theme-preview { width: 96rpx; height: 96rpx; margin: 0 auto 12rpx; border: 1rpx solid rgba(199,199,204,0.5); }
.theme-preview.light { background: #fff; } .theme-preview.dark { background: #1d1d1f; }
.theme-preview.auto { background: linear-gradient(135deg, #fff 50%, #1d1d1f 50%); }
.theme-name { font-size: 24rpx; color: #1d1d1f; }
.time-row { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; }
.time-label { font-size: 30rpx; color: #1d1d1f; }
.time-picker { display: flex; align-items: center; gap: 8rpx; padding: 12rpx 24rpx; background: #f5f5f7; }
.time-value { font-size: 30rpx; color: #1f8a4c; font-weight: 500; }
.time-arrow { font-size: 28rpx; color: #86868b; }
.time-hint { font-size: 22rpx; color: #86868b; margin-top: 12rpx; line-height: 1.5; }
.action-row { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 0; border-bottom: 1rpx solid rgba(199,199,204,0.2); }
.action-row:last-child { border-bottom: none; }
.action-row.danger .action-label { color: #ff3b30; }
.action-label { font-size: 30rpx; color: #1d1d1f; }
.action-arrow { font-size: 32rpx; color: #c7c7cc; font-weight: 300; }
.about-row { display: flex; justify-content: space-between; align-items: center; padding: 16rpx 0; }
.about-label { font-size: 28rpx; color: #86868b; }
.about-value { font-size: 28rpx; color: #1d1d1f; }
.footer { text-align: center; font-size: 24rpx; color: #c7c7cc; padding: 32rpx 0; }
.contact-btn { width: 100%; background: #1f8a4c; color: #fff; font-size: 30rpx; font-weight: 500; padding: 24rpx 0; text-align: center; letter-spacing: 1rpx; }
.contact-btn::after { border: none; }
.contact-hint { font-size: 22rpx; color: #c7c7cc; text-align: center; margin-top: 16rpx; line-height: 1.5; }
