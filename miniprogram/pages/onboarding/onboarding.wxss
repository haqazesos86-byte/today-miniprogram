.page { min-height: 100vh; background: var(--bg-primary, #fff); display: flex; flex-direction: column; }
.swiper { flex: 1; }
.slide { height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80rpx 60rpx; box-sizing: border-box; }
.slide-emoji { font-size: 200rpx; margin-bottom: 80rpx; animation: float 3s ease-in-out infinite; }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20rpx); } }
.slide-title { font-size: 56rpx; font-weight: 600; color: var(--text-primary, #1d1d1f); text-align: center; margin-bottom: 32rpx; letter-spacing: 1rpx; }
.slide-desc { font-size: 30rpx; color: var(--text-secondary, #86868b); text-align: center; line-height: 1.8; }
.footer { padding: 32rpx 40rpx 80rpx; display: flex; align-items: center; gap: 24rpx; }
.btn-skip { flex: 0 0 auto; padding: 24rpx 32rpx; font-size: 28rpx; color: var(--text-secondary, #86868b); }
.btn-primary { flex: 1; background: var(--accent, #1f8a4c); color: #fff; padding: 28rpx 0; font-size: 32rpx; font-weight: 500; text-align: center; letter-spacing: 2rpx; }
