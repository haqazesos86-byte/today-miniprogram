.page { min-height: 100vh; padding: 40rpx 40rpx 200rpx; background: var(--bg-tertiary, #fafafa); box-sizing: border-box; }
.hero { text-align: center; margin-bottom: 48rpx; }
.hero-emoji { font-size: 80rpx; margin-bottom: 16rpx; }
.hero-title { font-size: 36rpx; font-weight: 600; color: var(--text-primary, #1d1d1f); margin-bottom: 8rpx; }
.hero-desc { font-size: 26rpx; color: var(--text-secondary, #86868b); }
.section { background: var(--bg-primary, #fff); padding: 32rpx; margin-bottom: 24rpx; border: 1rpx solid var(--divider, rgba(199,199,204,0.3)); }
.section-title { font-size: 26rpx; font-weight: 600; color: var(--text-primary, #1d1d1f); margin-bottom: 24rpx; }
.type-list { display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16rpx; }
.type-item { display: flex; flex-direction: column; align-items: center; padding: 24rpx 0; background: var(--bg-secondary, #f5f5f7); border: 2rpx solid transparent; cursor: pointer; transition: all 0.2s; }
.type-item.active { background: rgba(31,138,76,0.1); border-color: var(--accent, #1f8a4c); }
.type-emoji { font-size: 40rpx; margin-bottom: 8rpx; }
.type-name { font-size: 24rpx; color: var(--text-primary, #1d1d1f); }
.textarea { width: 100%; min-height: 240rpx; font-size: 30rpx; color: var(--text-primary, #1d1d1f); line-height: 1.6; padding: 16rpx; background: var(--bg-secondary, #f5f5f7); box-sizing: border-box; }
.char-count { text-align: right; font-size: 22rpx; color: var(--text-tertiary, #c7c7cc); margin-top: 8rpx; }
.input { width: 100%; font-size: 28rpx; color: var(--text-primary, #1d1d1f); padding: 16rpx; background: var(--bg-secondary, #f5f5f7); box-sizing: border-box; height: 44rpx; }
.device-info { background: var(--bg-secondary, #f5f5f7); padding: 16rpx 24rpx; margin-bottom: 32rpx; }
.device-label { font-size: 22rpx; color: var(--text-tertiary, #c7c7cc); margin-bottom: 4rpx; }
.device-text { font-size: 24rpx; color: var(--text-secondary, #86868b); }
.action-area { position: fixed; bottom: 0; left: 0; right: 0; padding: 24rpx 40rpx 40rpx; background: var(--bg-primary, #fff); border-top: 1rpx solid var(--divider, rgba(199,199,204,0.3)); z-index: 10; }
.btn-submit { background: var(--accent, #1f8a4c); color: #fff; font-size: 32rpx; font-weight: 500; padding: 24rpx 0; text-align: center; letter-spacing: 2rpx; }
.btn-submit[disabled] { background: var(--text-tertiary, #c7c7cc); color: #fff; }
.btn-submit::after { border: none; }
.history-item { padding: 20rpx 0; border-bottom: 1rpx solid var(--divider, rgba(199,199,204,0.2)); }
.history-item:last-child { border-bottom: none; }
.history-meta { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx; }
.history-type { font-size: 24rpx; color: var(--accent, #1f8a4c); font-weight: 500; }
.history-time { font-size: 22rpx; color: var(--text-tertiary, #c7c7cc); }
.history-content { font-size: 28rpx; color: var(--text-primary, #1d1d1f); line-height: 1.5; }
